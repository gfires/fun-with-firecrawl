# Copy this file to `.env.local` and fill in real keys. `.env.local` is gitignored.

# Firecrawl — https://firecrawl.dev  (used for /search and /scrape)
FIRECRAWL_API_KEY=fc-...

# OpenAI — https://platform.openai.com  (used for the inference / scoring step)
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown). Only set if you want to change behavior.
# OPENAI_MODEL=gpt-4o
# SCAN_MAX_SCRAPE=28          # how many of the best search results to fully scrape
# SCAN_RESULTS_PER_INTENT=5   # search results requested per intent
